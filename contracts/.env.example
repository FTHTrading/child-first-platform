# Deployer wallet private key — generate with: pnpm generate-wallet
DEPLOYER_PRIVATE_KEY=

# Deployer wallet address (informational)
DEPLOYER_ADDRESS=

# ── Network RPCs ──────────────────────────────────────────────────────────────
POLYGON_MAINNET_RPC=https://polygon-rpc.com
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# ── Block explorer API keys (for contract verification) ───────────────────────
# Get yours free at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ── Gas reporter ──────────────────────────────────────────────────────────────
REPORT_GAS=false
