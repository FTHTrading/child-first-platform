# Child First Platform — Web Environment Variables
# Copy this file to .env.local and fill in the values

# ── Wallet Connect (required for MetaMask + WalletConnect support)
# Get a free Project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Blockchain ─────────────────────────────────────────────────────────────
# Deployed contract addresses (output of: cd contracts && pnpm deploy:testnet)
NEXT_PUBLIC_CAMPAIGN_FACTORY_ADDRESS=
NEXT_PUBLIC_DONATION_RECEIPT_ADDRESS=

# Chain ID: 80002 = Polygon Amoy testnet | 137 = Polygon mainnet
NEXT_PUBLIC_CHAIN_ID=80002

# Polygon RPC (optional — defaults to public endpoint)
NEXT_PUBLIC_POLYGON_RPC=https://rpc-amoy.polygon.technology

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string for off-chain metadata storage
DATABASE_URL="postgresql://postgres:password@localhost:5432/childfirst?schema=public"

# ── API ────────────────────────────────────────────────────────────────────
# Set for production; leave blank for local dev
NEXT_PUBLIC_API_BASE_URL=
